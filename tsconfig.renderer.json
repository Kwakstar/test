    "outDir": "./dist/renderer",
    "rootDir": "./src",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/shared/**/*.ts",
    "src/renderer/**/*.d.ts"
  ]
}
