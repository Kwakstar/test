{
  "name": "pressure-pal-control-room",
  "version": "0.1.0",
  "private": true,
  "author": "Kwakstar",
  "description": "Electron desktop app and Arduino Uno firmware for live pressure monitoring and solenoid control.",
  "main": "dist/main/main/main.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build:tests": "tsc -p tsconfig.tests.json",
    "copy:assets": "node scripts/copy-assets.mjs",
    "build": "cmd /c npm run clean && cmd /c npm run build:main && cmd /c npm run build:renderer && cmd /c npm run copy:assets",
    "firmware:build": "node scripts/build-firmware.mjs",
    "start": "cmd /c npm run build && electron .",
    "test": "cmd /c npm run build:tests && node scripts/run-tests.mjs",
    "dist:win": "cmd /c npm run build && electron-builder --win portable nsis"
  },
  "build": {
    "appId": "com.kwakstar.pressurepal",
    "productName": "Pressure Pal Control Room",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "firmware/dist",
        "to": "firmware",
        "filter": [
          "arduino-pressure-controller.uno.hex"
        ]
      },
      {
        "from": "tools/arduino-cli.exe",
        "to": "tools/arduino-cli.exe"
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "artifactName": "pressure-pal-control-room-${version}-${target}.${ext}"
    }
  },
  "dependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
